{
  "info": {
    "name": "EasyPostman Collection CLI Example",
    "description": "Uploads a fixture selected by the uploadFile environment variable to Postman Echo for every CSV row.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Upload API",
      "item": [
        {
          "name": "Upload fixture",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "{{uploadFile}}"
                },
                {
                  "key": "user",
                  "type": "text",
                  "value": "{{user}}"
                }
              ]
            },
            "url": "{{baseUrl}}/post?user={{user}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var response = pm.response.json();",
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('uploaded file is present', function () {",
                  "  pm.expect(response.files).to.have.property('sample-file.txt');",
                  "});",
                  "pm.test('iteration data reached the server', function () {",
                  "  pm.expect(response.form.user).to.equal(pm.iterationData.get('user'));",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
