[
    {
        "type": "group",
        "id": "functional-cli-example",
        "name": "EasyPostman Functional CLI Example",
        "description": "EasyPostman native workspace example for headless functional runs.",
        "children": [
            {
                "type": "group",
                "id": "upload-api",
                "name": "Upload API",
                "children": [
                    {
                        "type": "request",
                        "data": {
                            "id": "upload-fixture",
                            "name": "Upload fixture",
                            "url": "{{baseUrl}}/post?user={{user}}",
                            "method": "POST",
                            "bodyType": "form-data",
                            "formDataList": [
                                {
                                    "enabled": true,
                                    "key": "file",
                                    "type": "File",
                                    "value": "{{uploadFile}}"
                                },
                                {
                                    "enabled": true,
                                    "key": "user",
                                    "type": "Text",
                                    "value": "{{user}}"
                                }
                            ],
                            "postscript": "var response = pm.response.json();\npm.test('status is 200', function () { pm.response.to.have.status(200); });\npm.test('uploaded file is present', function () { pm.expect(response.files).to.have.property('file'); });\npm.test('iteration data reached the server', function () { pm.expect(response.form.user).to.equal(pm.iterationData.get('user')); });"
                        }
                    }
                ]
            }
        ]
    }
]
