<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE RSyntaxTheme SYSTEM "theme.dtd">

<!--
	EasyPostman Dark Theme
	Optimized dark theme for EasyPostman application
	Based on modern dark color schemes with improved readability
-->
<RSyntaxTheme version="1.0">

	<!-- Omitting baseFont will use a system-appropriate monospaced. -->
	<!--<baseFont family="..." size="13"/>-->

	<!-- General editor colors - IDEA-like dark editor surface -->
	<background color="1E1F22" />
	<caret color="CED0D6" />
	<selection useFG="false" bg="214283" roundedEdges="true" />  <!-- 蓝色选中背景，圆角 -->
	<currentLineHighlight color="25282D" fade="true" />  <!-- 当前行高亮 -->
	<marginLine fg="2B2D30" />  <!-- 边距线，暗色下避免过亮 -->
	<markAllHighlight color="364235" />  <!-- 标记所有匹配项 -->
	<markOccurrencesHighlight color="34475C" />  <!-- 标记出现次数 -->
	<matchedBracket fg="D6D8DE" bg="2E4A45" highlightBoth="true" animate="true" />  <!-- 匹配的括号 -->
	<hyperlinks fg="589DF6" />  <!-- 超链接 - 蓝色 -->

	<!-- 多语言支持 -->
	<secondaryLanguages>
		<language index="1" bg="1F2023" />
		<language index="2" bg="212327" />
		<language index="3" bg="23262A" />
	</secondaryLanguages>

	<!-- Gutter styling - 行号区域样式 -->
	<gutterBackground color="1C1D20" />
	<gutterBorder color="2B2D30" />
	<lineNumbers fg="6F737A" currentFG="AEB6C2"/>  <!-- 当前行号更亮 -->
	<foldIndicator fg="6F737A" armedFg="AEB6C2" iconBg="1C1D20" iconArmedBg="2B2D30" />
	<iconRowHeader activeLineRange="3592C4" />

	<!-- Syntax tokens - 语法高亮配色 -->
	<tokenStyles>
		<!-- NULL - 行结束标记 -->
		<style token="NULL" fg="C9CCD3" />

		<!-- 注释 - 灰绿色系 -->
		<style token="COMMENT_EOL" fg="7A7F87" italic="true" />
		<style token="COMMENT_MULTILINE" fg="7A7F87" italic="true" />
		<style token="COMMENT_DOCUMENTATION" fg="629755" italic="true" />
		<style token="COMMENT_KEYWORD" fg="629755" bold="true" italic="true" />
		<style token="COMMENT_MARKUP" fg="629755" italic="true" />

		<!-- 关键字 - 橙色系（JavaScript: function, var, const, let, if, else 等）-->
		<style token="RESERVED_WORD" fg="B392F0" />
		<style token="RESERVED_WORD_2" fg="B392F0" />

		<!-- 函数/方法 - 亮黄色（JavaScript: console.log, Array.map 等）-->
		<style token="FUNCTION" fg="56A8F5" />

		<!-- 字面量 - 布尔值 (true, false) -->
		<style token="LITERAL_BOOLEAN" fg="CF8E6D" />

		<!-- 字面量 - 数字（所有进制）-->
		<style token="LITERAL_NUMBER_DECIMAL_INT" fg="2AACB8" />
		<style token="LITERAL_NUMBER_FLOAT" fg="2AACB8" />
		<style token="LITERAL_NUMBER_HEXADECIMAL" fg="2AACB8" />

		<!-- 字符串 - 绿色（JavaScript 支持多种字符串）-->
		<style token="LITERAL_STRING_DOUBLE_QUOTE" fg="6AAB73" />
		<style token="LITERAL_CHAR" fg="6AAB73" />
		<style token="LITERAL_BACKQUOTE" fg="6AAB73" />  <!-- ES6 模板字符串 -->

		<!-- 数据类型 - 蓝绿色（Java: int, String, void 等）-->
		<style token="DATA_TYPE" fg="56A8F5" bold="true" />

		<!-- 变量 - 紫色（Java: @Autowired, @Override 等相关）-->
		<style token="VARIABLE" fg="C77DBB" />

		<!-- 正则表达式 - 橙红色 -->
		<style token="REGEX" fg="D5B778" />

		<!-- 注解 - 金黄色（Java: @Override, @Deprecated 等，用于 request、response 等 Postman 属性）-->
		<style token="ANNOTATION" fg="B3AE60" />

		<!-- 标识符 - 默认文字（变量名、函数名等）-->
		<style token="IDENTIFIER" fg="C9CCD3" />

		<!-- 空白 -->
		<style token="WHITESPACE" fg="C9CCD3" />

		<!-- 分隔符 - 橙色（括号、大括号、方括号等：{}[]()）-->
		<style token="SEPARATOR" fg="BCBEC4" />

		<!-- 操作符 - 浅灰色（+, -, *, /, =, ==, ===, !=, !==, &&, ||, !, ?, : 等）-->
		<style token="OPERATOR" fg="BCBEC4" />

		<!-- 预处理器 - 紫色（C/C++: #include, #define 等）-->
		<style token="PREPROCESSOR" fg="C77DBB" />

		<!-- HTML/XML 标签 -->
		<style token="MARKUP_TAG_DELIMITER" fg="CF8E6D" />
		<style token="MARKUP_TAG_NAME" fg="CF8E6D" bold="true" />
		<style token="MARKUP_TAG_ATTRIBUTE" fg="BCBEC4" />
		<style token="MARKUP_TAG_ATTRIBUTE_VALUE" fg="6AAB73" />
		<style token="MARKUP_COMMENT" fg="7A7F87" italic="true" />
		<style token="MARKUP_DTD" fg="C77DBB" />
		<style token="MARKUP_PROCESSING_INSTRUCTION" fg="C77DBB" />
		<style token="MARKUP_CDATA_DELIMITER" fg="C77DBB" />
		<style token="MARKUP_CDATA" fg="BCBEC4" />
		<style token="MARKUP_ENTITY_REFERENCE" fg="2AACB8" />

		<!-- 错误标记 - 红色背景 -->
		<style token="ERROR_IDENTIFIER" fg="DB5860" bg="3A2628" />
		<style token="ERROR_NUMBER_FORMAT" fg="DB5860" bg="3A2628" />
		<style token="ERROR_STRING_DOUBLE" fg="DB5860" bg="3A2628" />
		<style token="ERROR_CHAR" fg="DB5860" bg="3A2628" />
	</tokenStyles>

</RSyntaxTheme>
